{
  "name": "controlla",
  "version": "0.0.1",
  "description": "Fine-grained reactive state and fully typed router for React - async, derived, persisted, and keyed controls with surgical re-renders",
  "author": "Andrii Dubetskyi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Krombik/controlla.git"
  },
  "bugs": {
    "url": "https://github.com/Krombik/controlla/issues"
  },
  "homepage": "https://github.com/Krombik/controlla#readme",
  "type": "module",
  "source": "src/index.ts",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "release": "tsdown && npm publish ./build",
    "test": "tsdown && node --test --experimental-transform-types --no-warnings \"tests/*.test.ts\""
  },
  "peerDependencies": {
    "@types/react": ">=17.0.0",
    "react": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "keywords": [
    "react",
    "state",
    "state-management",
    "router",
    "routing",
    "reactive",
    "typescript",
    "typed",
    "async",
    "derived",
    "persist",
    "signals",
    "fine-grained",
    "url-state",
    "hooks"
  ],
  "imports": {
    "#internal/*": "./src/core/_internal/*.ts",
    "#core/*": "./src/core/*/index.ts",
    "#router/internal/*": "./src/router/_internal/*.ts",
    "#persist/internal/*": "./src/persist/_internal/*.ts",
    "#router/types": "./src/router/types.ts",
    "#persist/types": "./src/persist/types.ts",
    "#router/*": "./src/router/*/index.ts",
    "#persist/*": "./src/persist/*/index.ts",
    "#scheduler/*": "./src/scheduler/*/index.ts",
    "#types": "./src/core/types.ts"
  },
  "dependencies": {
    "keyweaver": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^19.2.17",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "unrun": "^0.3.1"
  },
  "sideEffects": false
}
